# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5001
HOST=::

# ─── MongoDB ──────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/
MONGODB_DB_NAME=myPlanning

# ─── Authentication ───────────────────────────────────────────────────────────
# REQUIRED — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=

# ─── reCAPTCHA ────────────────────────────────────────────────────────────────
# Get your keys at https://www.google.com/recaptcha/admin
RECAPTCHA_SECRET_KEY=

# ─── Email (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM=noreply@openglow.fr

# ─── Email (Nodemailer / SMTP fallback) ───────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ─── Cloudinary ───────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── CORS ─────────────────────────────────────────────────────────────────────
FRONTEND_URL=https://www.openglow.fr
# Comma-separated list of extra allowed origins (optional)
CORS_ALLOWED_ORIGINS=
